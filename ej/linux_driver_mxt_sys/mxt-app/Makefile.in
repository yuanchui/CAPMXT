.PRECIOUS: Makefile


.PHONY: force
git-version: force
	echo '$(GIT_VERSION)' | cmp -s - $@ || echo '$(GIT_VERSION)' > $@

.PHONY: doc
doc: doc/doxygen.cfg
	doxygen doc/doxygen.cfg

@ENABLE_MAN_TRUE@man1/mxt-app.1: README.md
@ENABLE_MAN_TRUE@	@$(MKDIR_P) man1/
@ENABLE_MAN_TRUE@	-pandoc -s -t man \
@ENABLE_MAN_TRUE@	-V title="MXT-APP" \
@ENABLE_MAN_TRUE@	-V section="1" \
@ENABLE_MAN_TRUE@	-V description="\"mxt-app $(GIT_VERSION)\"" \
@ENABLE_MAN_TRUE@	$(top_srcdir)/README.md -o man1/mxt-app.1

@ENABLE_ODT_TRUE@odt1/mxt-app.1: README.md
@ENABLE_ODT_TRUE@	@$(MKDIR_P) odt1/
@ENABLE_ODT_TRUE@	-pandoc -s -t odt \
@ENABLE_ODT_TRUE@	-V title="MXT-APP" \
@ENABLE_ODT_TRUE@	-V section="1" \
@ENABLE_ODT_TRUE@	-V description="\"mxt-app $(GIT_VERSION)\"" \
@ENABLE_ODT_TRUE@	$(top_srcdir)/README.md -o odt1/mxt-app.1

clean-local:
	-rm git-version
	-rm man1/mxt-app.1
	-rm -Rf doc/html

dist-hook:
	echo $(VERSION) > $(distdir)/VERSION

indent:
	astyle --style=linux --indent=spaces=2 \
	$(mxt_app_SOURCES) $(libmaxtouch_la_SOURCES)

ctags:
	find src -type f -name "*.[ch]" | xargs @CTAGS@

# Tell versions [3.59,3.63) of GNU make to not export all variables.
# Otherwise a system limit (for SysV at least) may be exceeded.
.NOEXPORT:

# Tell GNU make to disable its built-in pattern rules.
